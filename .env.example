# ============================================================
# SIPMS - Environment Variables Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!
# ============================================================

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/sipms_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password

# JWT Configuration (use a strong secret key)
JWT_SECRET=your_256_bit_secret_key_here_minimum_32_characters
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email / SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# AI Service Configuration
AI_ENABLED=true
# API_KEY will be read from system environment variable

# Application Settings
APP_ENV=development
APP_URL=http://localhost:8080

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB
