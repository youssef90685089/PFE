# SIPMS Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_URL=jdbc:mysql://localhost:3306/sipms_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# ============================================================
# JWT SECURITY CONFIGURATION (256-bit minimum for HS256)
# ============================================================
JWT_SECRET=your_256_bit_super_secret_key_at_least_32_characters_long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ============================================================
# CORS CONFIGURATION (comma-separated list)
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# EMAIL / SMTP CONFIGURATION
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# ============================================================
# AI SERVICE CONFIGURATION
# ============================================================
AI_ENABLED=true
API_KEY=aCi_81CsSmwAyqDXXFRwqgtqGPhjmSV1
AI_MODEL=gpt-4-mini

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_ENV=development
APP_URL=http://localhost:8080

# ============================================================
# RATE LIMITING CONFIGURATION
# ============================================================
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000